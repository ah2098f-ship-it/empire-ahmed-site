const express = require('expconst cors = require('cors');
const fs = require('fs');
const crypto = require('crypto');
const app = express();
const port = process.env.PORT || 3000;

// ===== المفتاح الملكي =====
const API_KEY = "290d9da4b0e8dbff9dca9173a2c2f6cf";
const JAP_API_URL = "https://api.example.com/v2";

app.use(cors());
app.use(express.json());
app.use(express.static('public'));

// ===== 1. تشفير البيانات (AES-256 + SHA-256) =====
function encryptData(text) {
    const cipher = crypto.createCipher('aes-256-cbc', 'empire-secret-key');
    let encrypted = cipher.update(text, 'utf8', 'hex');
    encrypted += cipher.final('hex');
    return encrypted;
}

function hashSHA256(text) {
    return crypto.createHash('sha256').update(text).digest('hex');
}

// ===== 2. نظام الحفظ التلقائي (Auto-Save) =====
const DATA_FILE = './database/empire_data.json';

function saveData(data) {
    fs.writeFileSync(DATA_FILE, JSON.stringify(data, null, 2));
}

function loadData() {
    if (fs.existsSync(DATA_FILE)) {
        return JSON.parse(fs.readFileSync(DATA_FILE, 'utf8'));
    }
    return { users: [], orders: [], balance: 4500.75, settings: { lang: 'ar' } };
}

// ===== 3. نظام الأمان والحماية (Security Engine) =====
const securityEngine = {
    fraudDetection: (orderData) => {
        const suspiciousPatterns = [
            orderData.quantity > 10000,
            orderData.ip && orderData.ip.includes('proxy'),
            orderData.amount > 5000
        ];
        return suspiciousPatterns.filter(Boolean).length > 1;
    },
    
    ddosProtection: (req) => {
        const cfIp = req.headers['cf-connecting-ip'];
        return cfIp ? true : false;
    },
    
    encryptDatabase: (data) => {
        return encryptData(JSON.stringify(data));
    }
};

// ===== 4. نظام الدفع التلقائي (Auto Payment) =====
const paymentSystem = {
    methods: {
        'ZainCash': '077860333563',
        'Asia': '07732554772',
        'Rafidain': 'Rafidain Bank'
    },
    
    processPayment: (amount, method) => {
        return {
            status: 'completed',
            transaction_id: 'TRX-' + Math.floor(Math.random() * 999999),
            method: method,
            amount: amount
        };
    }
};

// ===== 5. نظام البوتات المتكامل (Bot System) =====
const botSystem = {
    autoControl: {
        checkOrders: () => {
            return { pending: 12, completed: 45 };
        },
        autoRefund: (orderId) => {
            return { orderId, refunded: true, amount: 50.00 };
        }
    },
    
    supportBot: {
        responses: {
            'hello': 'مرحباً بك في إمبراطورية أحمد! كيف يمكنني مساعدتك؟',
            'order status': 'جاري التحقق من حالة طلبك...',
            'refund': 'سيتم معالجة طلب الاسترداد خلال 24 ساعة.'
        },
        autoReply: (message) => {
            const lower = message.toLowerCase();
            for (const [key, response] of Object.entries(this.responses)) {
                if (lower.includes(key)) return response;
            }
            return 'شكراً لتواصلك معنا. سنعود إليك قريباً.';
        }
    },
    
    orderAccelerator: {
        speedUp: (orderId) => {
            return { orderId, status: 'accelerated', newETA: '5 minutes' };
        }
    }
};

// ===== 6. نظام الرتب والمكافآت (Rank System) =====
const rankSystem = {
    ranks: {
        'Bronze': { discount: 0, minSpend: 0 },
        'Silver': { discount: 5, minSpend: 100 },
        'Gold': { discount: 10, minSpend: 500 },
        'Imperial': { discount: 20, minSpend: 1000 }
    },
    
    getRank: (spend) => {
        if (spend >= 1000) return 'Imperial';
        if (spend >= 500) return 'Gold';
        if (spend >= 100) return 'Silver';
        return 'Bronze';
    },
    
    calculateBonus: (amount, rank) => {
        const bonuses = { 'Bronze': 0, 'Silver': 2, 'Gold': 4, 'Imperial': 7 };
        return (amount * bonuses[rank]) / 100;
    }
};

// ===== 7. ربط الـ API مع JAP (مع تعريب الخدمات) =====
function translateServices(services, lang = 'ar') {
    const translations = {
        'Instagram': { 'ar': 'إنستغرام', 'en': 'Instagram' },
        'TikTok': { 'ar': 'تيك توك', 'en': 'TikTok' },
        'Telegram': { 'ar': 'تيليجرام', 'en': 'Telegram' },
        'Facebook': { 'ar': 'فيسبوك', 'en': 'Facebook' },
        'YouTube': { 'ar': 'يوتيوب', 'en': 'YouTube' },
        'Twitter': { 'ar': 'تويتر', 'en': 'Twitter' },
        'Followers': { 'ar': 'متابعين', 'en': 'Followers' },
        'Likes': { 'ar': 'إعجابات', 'en': 'Likes' },
        'Views': { 'ar': 'مشاهدات', 'en': 'Views' },
        'Members': { 'ar': 'أعضاء', 'en': 'Members' }
    };
    
    return services.map(service => {
        let name = service.name || service;
        for (const [key, value] of Object.entries(translations)) {
            if (name.includes(key)) {
                name = name.replace(key, value[lang]);
            }
        }
        return { ...service, name };
    });
}

async function fetchJAPServices(lang = 'ar') {
    try {
        const response = await fetch(`${JAP_API_URL}/services?key=${API_KEY}`);
        const data = await response.json();
        return translateServices(data.services || [], lang);
    } catch (error) {
        return { error: 'فشل الاتصال بسيرفر JAP', services: [] };
    }
}

// ===== 8. API Endpoints =====

// تسجيل الدخول مع التحقق
app.post('/api/login', (req, res) => {
    const { username, password } = req.body;
    const hashed = hashSHA256(password);
    res.json({
        status: 'success',
        token: 'JWT_' + hashed.substring(0, 10),
        verified: true,
        security: {
            encryption: 'AES-256',
            hashing: 'SHA-256',
            twoFactor: 'OTP Enabled'
        }
    });
});

// جلب الرصيد
app.post('/api/balance', async (req, res) => {
    const data = loadData();
    res.json({
        balance: data.balance || 4500.75,
        currency: 'USD',
        iqd_equivalent: (data.balance || 4500.75) * 1500,
        api_key_used: API_KEY
    });
});

// إنشاء طلب جديد
app.post('/api/order', (req, res) => {
    const { link, quantity, service_type, service_id } = req.body;
    const data = loadData();
    
    if (securityEngine.fraudDetection(req.body)) {
        return res.status(403).json({
            error: '⚠️ تم اكتشاف نشاط مشبوه. تم حظر الطلب.'
        });
    }
    
    const basePrice = 0.50;
    const total = quantity * basePrice;
    
    if (total > data.balance) {
        return res.status(400).json({
            error: '❌ الرصيد غير كافي. الرصيد المتاح: ' + data.balance
        });
    }
    
    data.balance -= total;
    
    const order = {
        id: 'ORD-' + Math.floor(Math.random() * 999999),
        link: link,
        quantity: quantity,
        service: service_type || 'standard',
        price: total,
        status: 'processing',
        created_at: new Date().toISOString(),
        guarantee: service_id === 'guaranteed' ? '30-day' : 'standard'
    };
    
    data.orders.push(order);
    saveData(data);
    
    if (service_type === 'fast') {
        botSystem.orderAccelerator.speedUp(order.id);
    }
    
    res.json({
        success: true,
        order: order,
        message: '✅ تم تنفيذ الأمر الملكي بنجاح',
        remaining_balance: data.balance
    });
});

// إلغاء الطلب واسترداد الأموال
app.post('/api/cancel-order', (req, res) => {
    const { orderId } = req.body;
    const data = loadData();
    
    const orderIndex = data.orders.findIndex(o => o.id === orderId);
    if (orderIndex === -1) {
        return res.status(404).json({ error: 'الطلب غير موجود' });
    }
    
    const order = data.orders[orderIndex];
    if (order.status === 'completed') {
        return res.status(400).json({ error: 'لا يمكن إلغاء طلب مكتمل' });
    }
    
    data.balance += order.price;
    data.orders[orderIndex].status = 'cancelled';
    saveData(data);
    
    res.json({
        success: true,
        refunded_amount: order.price,
        new_balance: data.balance,
        message: '✅ تم إلغاء الطلب واسترداد المبلغ بنجاح'
    });
});

// جلب الخدمات من JAP (مع دعم اللغة)
app.post('/api/fetch-services', async (req, res) => {
    const { lang = 'ar' } = req.body;
    const services = await fetchJAPServices(lang);
    res.json(services);
});

// نظام البونص
app.post('/api/bonus', (req, res) => {
    const { userId, amount, userType } = req.body;
    const data = loadData();
    
    let bonusPercentage = userType === 'supplier' ? 7 : 4;
    const bonus = (amount * bonusPercentage) / 100;
    
    data.balance += bonus;
    saveData(data);
    
    res.json({
        bonus: bonus,
        new_balance: data.balance,
        percentage: bonusPercentage + '%'
    });
});

// حفظ تفضيل اللغة
app.post('/api/save-lang', (req, res) => {
    const { lang } = req.body;
    const data = loadData();
    data.settings.lang = lang;
    saveData(data);
    res.json({ success: true, lang: lang });
});

